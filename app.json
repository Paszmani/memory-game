{
  "expo": {
    "name": "Jogo da Memória",
    "slug": "memory-game-gruposb",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "ios": { "supportsTablet": true, "bundleIdentifier": "com.memorygame.gruposb" },
    "android": {
      "adaptiveIcon": { "foregroundImage": "./assets/adaptive-icon.png", "backgroundColor": "#0A0A0A" },
      "edgeToEdgeEnabled": true, "package": "com.memorygame.gruposb"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png",
      "name": "Jogo da Memória",
      "shortName": "Memória",
      "description": "Jogo da memória personalizável",
      "backgroundColor": "#0A0A0A",
      "themeColor": "#FFD600",
      "lang": "pt-BR"
    },
    "plugins": [
      "expo-router",
      ["expo-image-picker", {
        "photosPermission": "O app precisa acessar suas fotos para personalizar o jogo."
      }]
    ],
    "experiments": {
      "typedRoutes": true,
      "baseUrl": "/memory-game"
    }
  }
}
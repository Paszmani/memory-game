{
  "expo": {
    "name": "Jogo da Memória Grupo SB",
    "slug": "memory-game-totem",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/sb-logo-icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/sb-logo-adaptive-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.memorygame.totem"
    },
    "android": {
      "package": "com.gruposb.memorygame",
      "versionCode": 1,
      "userInterfaceStyle": "dark",
      "adaptiveIcon": {
        "foregroundImage": "./assets/sb-logo-icon.png",
        "backgroundColor": "#0A0A0A"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/sb-logo-adaptive-icon.png",
      "name": "Jogo da Memória Grupo SB",
      "shortName": "Memória",
      "description": "Jogo da memória personalizável para totem e web",
      "backgroundColor": "#0A0A0A",
      "themeColor": "#FFD600",
      "lang": "pt-BR"
    },
    "plugins": [
      "expo-router",
      "expo-system-ui",
      [
        "expo-image-picker",
        {
          "photosPermission": "O app precisa acessar suas fotos para personalizar o jogo."
        }
      ],
      "expo-font",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true,
      "baseUrl": "/memory-game"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "44bf5463-e4bf-49e2-8cb8-355907e39158"
      }
    }
  }
}
